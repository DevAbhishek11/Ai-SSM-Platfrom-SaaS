{
  "title": "SSM Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "stat",
      "title": "API p95 Latency",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ssm-api\"}[5m])) by (le))"
        }
      ]
    },
    {
      "type": "stat",
      "title": "API Error Rate",
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"ssm-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"ssm-api\"}[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Publishing Queue Depth",
      "targets": [
        {
          "expr": "ssm_publishing_queue_depth"
        }
      ]
    }
  ]
}
